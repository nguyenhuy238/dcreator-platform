generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  CREATOR
  BRAND_OWNER
  BRAND_STAFF
  ADMIN
  OPS
}

enum ApplicationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum CreatorSocialLinkStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CreatorChannelVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  FACEBOOK
  SHOPEE
  OTHER
}

enum BrandMemberRole {
  OWNER
  MANAGER
  STAFF
}

enum BrandMemberStatus {
  ACTIVE
  INACTIVE
}

enum BrandStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  REJECTED
  PENDING_VERIFICATION
}

enum BrandSubscriptionPackageCode {
  FREE
  UGC_15_VIDEO
  UGC_50_VIDEO
}

enum FulfillmentType {
  NONE_WAREHOUSE
  BRAND_FULFILLMENT
}

enum OpsReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RoleRequestType {
  CREATOR
  BRAND
}

enum RoleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RiskFlagStatus {
  OPEN
  RESOLVED
  ESCALATED
}

enum CampaignType {
  DONATION
  PREORDER
  SPONSORSHIP
  COMMUNITY
}

enum CampaignSetupSource {
  JOIN_EXISTING_DCREATOR_CAMP
  BRAND_REQUESTED
}

enum CampaignFeasibilityStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  NEEDS_ADJUSTMENT
  REJECTED
}

enum BrandCampaignApprovalStatus {
  DRAFT
  WAITING_DCREATOR_REVIEW
  WAITING_BRAND_APPROVAL
  APPROVED
  CHANGE_REQUESTED
}

enum BrandCampaignRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum CampaignCategory {
  TECH
  FASHION
  FOOD
  BEAUTY
  LIFESTYLE
  EDUCATION
}

enum MissionStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
}

enum MissionAudience {
  USER
  CREATOR
}

enum ProductReceiveOption {
  DEPOSIT_PRODUCT
  CREATOR_BUY_FIRST
  NO_PRODUCT_REQUIRED
}

enum MissionLifecycleStatus {
  OPEN
  ACCEPTED
  DOING
  SUBMITTED
  PENDING_REVIEW
  APPROVED
  DONE
  REJECTED
  EXPIRED
  CANCELLED
}

enum CreatorMissionStatus {
  PRODUCT_PENDING
  DRAFT_PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductStatus {
  NOT_REQUIRED
  WAITING_DEPOSIT
  WAITING_PURCHASE
  RECEIVED
}

enum DepositStatus {
  NOT_REQUIRED
  PENDING
  PAID
  REFUND_PENDING
  REFUNDED
}

enum ReimbursementStatus {
  NOT_REQUIRED
  PENDING
  PURCHASE_SUBMITTED
  APPROVED
  PAYOUT_PENDING
  PAID
  REJECTED
}

enum CreatorMissionVideoReviewStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum CreatorMissionPublishStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum ReviewDecision {
  APPROVED
  REJECTED
}

enum TransactionType {
  TOPUP
  SUPPORT
  REWARD_REDEEM
  PAYOUT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum WalletTransactionType {
  TOPUP
  SUPPORT
  REWARD_REDEEM
  COMMISSION_CREDIT
  COMMISSION_PAYOUT
  ADJUSTMENT
}

enum NPointTopupRequestStatus {
  PENDING_ADMIN_REVIEW
  APPROVED
  REJECTED
  REFUND_INFO_SUBMITTED
  REFUND_COMPLETED
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ProductReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum InventoryStockStatus {
  IN_STOCK
  RESERVED
  OUT_OF_STOCK
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  FAILED
  COMPLETED
}

enum ContributionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ContributionPaymentMethod {
  N_POINTS
  PAYOS
}

enum RewardType {
  PHYSICAL_PRODUCT
  DIGITAL_VOUCHER
  EXPERIENCE
  CREATOR_PERK
  DISCOUNT_CODE
}

enum VoucherStatus {
  ISSUED
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum VoucherUsageType {
  ONE_TIME
  MULTI_USE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum NotificationEvent {
  USER_CONTRIBUTION_SUCCESS
  USER_RECEIVED_VOUCHER
  MISSION_ACCEPTED
  PROOF_SUBMITTED
  PROOF_APPROVED
  PROOF_REJECTED
  MISSION_APPLICATION_APPROVED
  MISSION_APPLICATION_REJECTED
  CREATOR_MISSION_VIDEO_APPROVED
  CREATOR_MISSION_VIDEO_REJECTED
  CREATOR_MISSION_FINAL_APPROVED
  CREATOR_MISSION_FINAL_REJECTED
  CREATOR_APPLICATION_APPROVED
  BRAND_APPLICATION_APPROVED
  CAMPAIGN_APPROVED
  CAMPAIGN_REJECTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYOUT_REQUESTED
  PAYOUT_APPROVED
  PAYOUT_REJECTED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketCategory {
  CONTENT
  REVENUE
  PAYOUT
  CAMPAIGN
  APPLICATION
  FULFILLMENT
  ACCOUNT
  OTHER
}

enum AnalyticsEventName {
  campaign_view
  campaign_cta_click
  campaign_support_started
  campaign_contribution_success
  reward_selected
  voucher_issued
  voucher_redeemed
  mission_accept
  mission_submit
  proof_approved
  proof_rejected
  creator_apply_job
  brand_create_campaign
  payment_success
  payment_failed
}

model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  avatarUrl    String?
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns                     Campaign[]             @relation("CampaignBrand")
  campaignsAsCreator            Campaign[]             @relation("CampaignCreator")
  wallet                        Wallet?
  profile                       Profile?
  submissions                   MissionSubmission[]
  proofReviews                  ProofReview[]
  supports                      Contribution[]
  auditLogs                     AuditLog[]
  notifications                 Notification[]
  riskFlags                     RiskFlag[]             @relation("RiskFlagAccount")
  resolvedRiskFlags             RiskFlag[]             @relation("RiskFlagResolver")
  internalNotes                 InternalNote[]         @relation("InternalNoteActor")
  sessions                      AuthSession[]
  roleRequests                  RoleRequest[]          @relation("RoleRequestApplicant")
  reviewedRoleRequests          RoleRequest[]          @relation("RoleRequestReviewer")
  walletTransactions            WalletTransaction[]
  paymentTransactions           PaymentTransaction[]
  payoutRequests                PayoutRequest[]
  rewardClaims                  RewardClaim[]
  analyticsEvents               AnalyticsEvent[]
  roleAssignments               AccountRole[]
  creatorApplications           CreatorApplication[]
  creatorProfile                CreatorProfile?
  brandApplications             BrandApplication[]
  ownedBrandMemberships         BrandMember[]          @relation("BrandMemberAccount")
  reviewedCreatorApplications   CreatorApplication[]   @relation("CreatorApplicationReviewer")
  reviewedCreatorSocialLinks    CreatorSocialLink[]    @relation("CreatorSocialLinkReviewer")
  reviewedBrandApplications     BrandApplication[]     @relation("BrandApplicationReviewer")
  reviewedBrands                Brand[]                @relation("BrandReviewer")
  reviewedBrandCampaignRequests BrandCampaignRequest[] @relation("BrandCampaignRequestReviewer")
  ownedBrands                   Brand[]                @relation("BrandOwner")
  reviewedProductSubmissions    ProductSubmission[]    @relation("ProductSubmissionReviewer")
  creatorFulfillmentOrders      FulfillmentOrder[]     @relation("FulfillmentCreator")
  supportTicketsRequested       SupportTicket[]        @relation("SupportTicketRequester")
  supportTicketsAssigned        SupportTicket[]        @relation("SupportTicketAssignee")
  supportTicketComments         SupportTicketComment[] @relation("SupportTicketCommentAuthor")
  creatorMissions               CreatorMission[]
  settings                      AccountSettings?
  appliedMissionApplications    MissionApplication[]   @relation("MissionApplicationAccount")
  reviewedMissionApplications   MissionApplication[]   @relation("MissionApplicationReviewer")
  requestedNPointTopups         NPointTopupRequest[]   @relation("NPointTopupRequester")
  reviewedNPointTopups          NPointTopupRequest[]   @relation("NPointTopupReviewer")
  processedNPointRefunds        NPointTopupRequest[]   @relation("NPointRefundProcessor")
}

model AccountRole {
  id        String   @id @default(cuid())
  accountId String
  role      Role
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, role])
  @@index([role, createdAt])
}

model CreatorApplication {
  id                String            @id @default(cuid())
  accountId         String
  status            ApplicationStatus @default(PENDING_REVIEW)
  displayName       String
  avatarUrl         String?
  bio               String?
  mainPlatform      SocialPlatform
  socialUrl         String
  handle            String?
  followerCount     Int?
  contentCategory   String?
  portfolioUrl      String?
  location          String?
  expectedRate      Int?
  maxJobsPerMonth   Int?
  realName          String?
  phone             String?
  identityNumber    String?
  identityFrontUrl  String?
  identityBackUrl   String?
  selfieUrl         String?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  taxCode           String?
  rejectReason      String?
  reviewNote        String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy Account? @relation("CreatorApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model CreatorProfile {
  id                String          @id @default(cuid())
  accountId         String          @unique
  displayName       String
  avatarUrl         String?
  bio               String?
  mainPlatform      SocialPlatform?
  socialUrl         String?
  handle            String?
  followerCount     Int?
  contentCategory   String?
  portfolioUrl      String?
  location          String?
  expectedRate      Int?
  maxJobsPerMonth   Int?
  realName          String?
  phone             String?
  identityNumber    String?
  identityFrontUrl  String?
  identityBackUrl   String?
  selfieUrl         String?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  taxCode           String?
  isSuspended       Boolean         @default(false)
  suspendedAt       DateTime?
  suspendedReason   String?
  unsuspendedAt     DateTime?
  unsuspendedReason String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  account     Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  socialLinks CreatorSocialLink[]
}

model CreatorSocialLink {
  id               String                  @id @default(cuid())
  creatorProfileId String
  platform         SocialPlatform
  handle           String?
  socialUrl        String
  followers        Int                     @default(0)
  engagementRate   Float?
  isActive         Boolean                 @default(true)
  verificationStatus CreatorChannelVerificationStatus @default(UNVERIFIED)
  status           CreatorSocialLinkStatus @default(PENDING)
  rejectReason     String?
  reviewNote       String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  reviewedBy     Account?       @relation("CreatorSocialLinkReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([creatorProfileId, platform, socialUrl])
  @@unique([creatorProfileId, platform, handle])
  @@index([creatorProfileId, createdAt])
  @@index([status, createdAt])
  @@index([creatorProfileId, isActive])
}

model BrandApplication {
  id                           String            @id @default(cuid())
  accountId                    String
  status                       ApplicationStatus @default(PENDING_REVIEW)
  brandName                    String
  logoUrl                      String?
  legalName                    String?
  industry                     String?
  website                      String?
  fanpage                      String?
  address                      String?
  contactName                  String
  contactPhone                 String
  contactEmail                 String
  description                  String?
  businessGoal                 String?
  taxCode                      String?
  businessLicenseUrl           String?
  representativeName           String?
  representativePhone          String?
  representativeEmail          String?
  representativeIdentityNumber String?
  bankAccountName              String?
  bankAccountNumber            String?
  bankName                     String?
  productCategories            String?
  inventoryDescription         String?
  expectedCampaignBudget       Int?
  expectedCreatorCount         Int?
  revenueSharePercent          Int?
  commissionRatePercent        Int?
  bccAgreementAccepted         Boolean           @default(false)
  bccAgreementVersion          String?
  bccAgreementTerms            String?
  legalResponsibilityAccepted  Boolean           @default(false)
  contractFileUrl              String?
  contractSignedAt             DateTime?
  rejectReason                 String?
  reviewNote                   String?
  reviewedById                 String?
  reviewedAt                   DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy Account? @relation("BrandApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model Brand {
  id                          String      @id @default(cuid())
  ownerAccountId              String
  name                        String
  logoUrl                     String?
  legalName                   String?
  industry                    String?
  website                     String?
  fanpage                     String?
  address                     String?
  contactName                 String
  contactPhone                String
  contactEmail                String
  description                 String?
  businessGoal                String?
  taxCode                     String?
  businessLicenseUrl          String?
  representativeName          String?
  representativePhone         String?
  representativeEmail         String?
  productCategories           String?
  inventoryDescription        String?
  revenueSharePercent         Int?
  commissionRatePercent       Int?
  bccAgreementVersion         String?
  bccAgreementTerms           String?
  legalResponsibilityAccepted Boolean     @default(false)
  contractFileUrl             String?
  contractSignedAt            DateTime?
  status                      BrandStatus @default(PENDING_VERIFICATION)
  reviewedById                String?
  reviewedAt                  DateTime?
  isLocked                    Boolean     @default(false)
  lockedAt                    DateTime?
  lockReason                  String?
  unlockedAt                  DateTime?
  unlockReason                String?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  owner               Account                @relation("BrandOwner", fields: [ownerAccountId], references: [id], onDelete: Restrict)
  reviewedBy          Account?               @relation("BrandReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  members             BrandMember[]
  products            BrandProduct[]
  campaignRequests    BrandCampaignRequest[]
  productSubmissions  ProductSubmission[]
  nPointTopupRequests NPointTopupRequest[]
  subscription        BrandSubscription?
}

model BrandSubscription {
  id          String                       @id @default(cuid())
  brandId     String                       @unique
  packageCode BrandSubscriptionPackageCode @default(FREE)
  activatedAt DateTime?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

model BrandCampaignRequest {
  id                       String                     @id @default(cuid())
  brandId                  String
  requestedSlug            String
  title                    String
  brief                    String
  setupSource              CampaignSetupSource        @default(BRAND_REQUESTED)
  benefits                 String?
  participationRoadmap     String[]                   @default([])
  objective                String?
  priorityChannels         String?
  missionTypes             String?
  creatorCommissionPercent Int                        @default(0)
  userCommissionPercent    Int                        @default(0)
  bonusBudgetVnd           Int                        @default(0)
  budgetVnd                Int
  targetAmountVnd          Int                        @default(10000000)
  campaignType             CampaignType               @default(COMMUNITY)
  category                 CampaignCategory           @default(LIFESTYLE)
  startsAt                 DateTime?
  endsAt                   DateTime?
  status                   BrandCampaignRequestStatus @default(PENDING_REVIEW)
  adminNote                String?
  brandFeedback            String?
  createdCampaignId        String?
  reviewedById             String?
  reviewedAt               DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdCampaign Campaign? @relation("CampaignFromBrandRequest", fields: [createdCampaignId], references: [id], onDelete: SetNull)
  reviewedBy      Account?  @relation("BrandCampaignRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([brandId, createdAt])
  @@index([status, createdAt])
  @@index([createdCampaignId])
}

model BrandProduct {
  id                  String   @id @default(cuid())
  brandId             String
  sku                 String
  name                String
  description         String?
  imageUrl            String?
  stockQty            Int      @default(0)
  voucherStock        Int      @default(0)
  campaignEligibility Boolean  @default(true)
  suggestedPriceVnd   Int      @default(0)
  costPriceVnd        Int      @default(0)
  priceVnd            Int      @default(0)
  pricePoints         Int      @default(0)
  returnPolicy        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  brand   Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  batches BrandInventoryBatch[]

  @@unique([brandId, sku])
  @@index([brandId, createdAt])
  @@index([campaignEligibility])
}

model BrandInventoryBatch {
  id                  String          @id @default(cuid())
  productId           String
  quantity            Int             @default(0)
  expiryDate          DateTime?
  fulfillmentType     FulfillmentType @default(BRAND_FULFILLMENT)
  opsStatus           OpsReviewStatus @default(PENDING_REVIEW)
  appraisedValueVnd   Int             @default(0)
  viableMarginPercent Int             @default(0)
  opsNote             String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  product BrandProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([opsStatus])
}

model BrandMember {
  id        String          @id @default(cuid())
  brandId   String
  accountId String
  role      BrandMemberRole @default(STAFF)
  status    BrandMemberStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  account Account @relation("BrandMemberAccount", fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([brandId, accountId])
  @@index([accountId, role, status])
}

model AuthSession {
  id        String    @id @default(cuid())
  accountId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model AccountSettings {
  id                        String   @id @default(cuid())
  accountId                 String   @unique
  notifyReviewStatusEmail   Boolean  @default(true)
  notifyVoucherMissionEmail Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, updatedAt])
}

model RoleRequest {
  id           String            @id @default(cuid())
  accountId    String
  type         RoleRequestType
  status       RoleRequestStatus @default(PENDING)
  brandName    String?
  brandWebsite String?
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  account    Account  @relation("RoleRequestApplicant", fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy Account? @relation("RoleRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([type, status])
}

model Profile {
  id          String   @id @default(cuid())
  accountId   String   @unique
  bio         String?
  phone       String?
  socialLinks Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
}

model Campaign {
  id                       String                      @id @default(cuid())
  brandId                  String
  creatorId                String?
  slug                     String                      @unique
  title                    String
  brief                    String
  coverImageUrl            String?
  campaignType             CampaignType                @default(COMMUNITY)
  setupSource              CampaignSetupSource         @default(BRAND_REQUESTED)
  benefits                 String?
  participationRoadmap     String[]                    @default([])
  objective                String?
  priorityChannels         String?
  missionTypes             String?
  creatorCommissionPercent Int                         @default(0)
  userCommissionPercent    Int                         @default(0)
  bonusBudgetVnd           Int                         @default(0)
  feasibilityStatus        CampaignFeasibilityStatus   @default(DRAFT)
  feasibilityNote          String?
  brandApprovalStatus      BrandCampaignApprovalStatus @default(DRAFT)
  brandFeedback            String?
  category                 CampaignCategory            @default(LIFESTYLE)
  targetAmountVnd          Int                         @default(10000000)
  fundedAmountVnd          Int                         @default(0)
  backerCount              Int                         @default(0)
  ugcVideoQuota            Int?
  ugcVideoApprovedCount    Int                         @default(0)
  isPublic                 Boolean                     @default(true)
  budgetVnd                Int
  status                   CampaignStatus              @default(DRAFT)
  movedToAuditAt           DateTime?
  movedToAuditById         String?
  pausedReason             String?
  resumedReason            String?
  forceClosedAt            DateTime?
  forceCloseReason         String?
  startsAt                 DateTime?
  endsAt                   DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  brand               Account                @relation("CampaignBrand", fields: [brandId], references: [id])
  creator             Account?               @relation("CampaignCreator", fields: [creatorId], references: [id])
  missions            Mission[]
  rewards             Reward[]
  contributions       Contribution[]
  paymentOrders       PaymentOrder[]
  analytics           AnalyticsDaily[]
  analyticsEvents     AnalyticsEvent[]
  sourceBrandRequests BrandCampaignRequest[] @relation("CampaignFromBrandRequest")
  fulfillmentOrders   FulfillmentOrder[]
  productSubmissions  ProductSubmission[]
  creatorMissions     CreatorMission[]
  missionApplications MissionApplication[]

  @@index([isPublic, status, updatedAt])
  @@index([isPublic, status, createdAt])
  @@index([isPublic, status, endsAt])
  @@index([isPublic, status, fundedAmountVnd])
  @@index([isPublic, status, backerCount])
}

model ProductSubmission {
  id           String              @id @default(cuid())
  brandId      String
  campaignId   String?
  name         String
  sku          String?
  description  String?
  unitPriceVnd Int                 @default(0)
  reviewStatus ProductReviewStatus @default(DRAFT)
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  brand            Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  reviewedBy       Account?         @relation("ProductSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  inventoryBatches InventoryBatch[]

  @@index([brandId, reviewStatus, createdAt])
  @@index([campaignId, reviewStatus, createdAt])
}

model InventoryBatch {
  id                  String               @id @default(cuid())
  productSubmissionId String
  batchCode           String?
  quantityTotal       Int
  quantityReserved    Int                  @default(0)
  quantityRemaining   Int
  stockStatus         InventoryStockStatus @default(IN_STOCK)
  expiresAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  productSubmission ProductSubmission  @relation(fields: [productSubmissionId], references: [id], onDelete: Cascade)
  fulfillmentOrders FulfillmentOrder[]

  @@index([productSubmissionId, stockStatus, createdAt])
}

model FulfillmentOrder {
  id               String            @id @default(cuid())
  campaignId       String?
  inventoryBatchId String?
  creatorAccountId String?
  recipientName    String?
  recipientPhone   String?
  shippingAddress  String?
  status           FulfillmentStatus @default(PENDING)
  failureReason    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  inventoryBatch InventoryBatch? @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)
  creatorAccount Account?        @relation("FulfillmentCreator", fields: [creatorAccountId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([campaignId, status, createdAt])
}

model Mission {
  id                   String               @id @default(cuid())
  campaignId           String
  title                String
  description          String
  productLink          String?
  rewardPoints         Int
  rewardCommissionVnd  Int                  @default(0)
  audience             MissionAudience      @default(USER)
  productReceiveOption ProductReceiveOption @default(NO_PRODUCT_REQUIRED)
  allowRepeat          Boolean              @default(false)
  deadlineAt           DateTime?
  status               MissionStatus        @default(OPEN)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  campaign        Campaign             @relation(fields: [campaignId], references: [id])
  proofReviews    ProofReview[]
  submissions     MissionSubmission[]
  creatorMissions CreatorMission[]
  applications    MissionApplication[]
}

model MissionApplication {
  id           String            @id @default(cuid())
  missionId    String
  campaignId   String
  accountId    String
  status       ApplicationStatus @default(PENDING_REVIEW)
  note         String?
  rejectReason String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  mission        Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  campaign       Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account        Account         @relation("MissionApplicationAccount", fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy     Account?        @relation("MissionApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  creatorMission CreatorMission?

  @@unique([missionId, accountId])
  @@index([accountId, status, createdAt])
  @@index([campaignId, status, createdAt])
  @@index([status, createdAt])
}

model MissionSubmission {
  id                         String                 @id @default(cuid())
  missionId                  String
  accountId                  String
  lifecycleStatus            MissionLifecycleStatus @default(ACCEPTED)
  videoUrl                   String?
  imageUrl                   String?
  socialPostUrl              String?
  screenshotUrl              String?
  fileUploadUrl              String?
  proofTextNote              String?
  note                       String?
  rejectReason               String?
  purchaseBillImageUrl       String?
  productReviewScreenshotUrl String?
  purchaseProofNote          String?
  purchaseConfirmedAt        DateTime?
  publicVideoUrl             String?
  adCode                     String?
  finalProofNote             String?
  finalSubmittedAt           DateTime?
  approvedAt                 DateTime?
  rewardGrantedAt            DateTime?
  rewardHold                Boolean                @default(false)
  rewardHoldReason          String?
  rewardHeldAt              DateTime?
  rewardHeldById            String?
  rewardReleasedAt          DateTime?
  rewardReleasedById        String?
  disputeStatus             String?
  status                     MissionStatus          @default(SUBMITTED)
  reviewedById               String?
  reviewedAt                 DateTime?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  mission        Mission         @relation(fields: [missionId], references: [id])
  account        Account         @relation(fields: [accountId], references: [id])
  reviews        ProofReview[]
  creatorMission CreatorMission?

  @@unique([missionId, accountId])
  @@index([accountId, lifecycleStatus, createdAt])
}

model CreatorMission {
  id                          String                          @id @default(cuid())
  missionId                   String
  campaignId                  String
  accountId                   String
  applicationStatus           ApplicationStatus               @default(PENDING_REVIEW)
  applicationNote             String?
  applicationRejectReason     String?
  applicationReviewedById     String?
  applicationReviewedAt       DateTime?
  appliedAt                   DateTime                        @default(now())
  submissionLifecycleStatus   MissionLifecycleStatus          @default(ACCEPTED)
  submissionStatus            MissionStatus                   @default(SUBMITTED)
  submissionVideoUrl          String?
  submissionImageUrl          String?
  submissionSocialPostUrl     String?
  submissionScreenshotUrl     String?
  submissionFileUploadUrl     String?
  submissionProofTextNote     String?
  submissionNote              String?
  submissionRejectReason      String?
  submissionPurchaseBillImageUrl String?
  submissionProductReviewScreenshotUrl String?
  submissionPurchaseProofNote String?
  submissionPurchaseConfirmedAt DateTime?
  submissionPublicVideoUrl    String?
  submissionAdCode            String?
  submissionFinalProofNote    String?
  submissionFinalSubmittedAt  DateTime?
  submissionApprovedAt        DateTime?
  submissionRewardGrantedAt   DateTime?
  submissionReviewedById      String?
  submissionReviewedAt        DateTime?
  submissionId                String?                         @unique
  missionApplicationId        String?                         @unique
  status                      CreatorMissionStatus
  productReceiveOption        ProductReceiveOption
  productStatus               ProductStatus
  depositStatus               DepositStatus
  reimbursementStatus         ReimbursementStatus
  purchaseProofTextNote       String?
  purchaseProofScreenshotUrl  String?
  purchaseProofNote           String?
  purchaseProofSubmittedAt    DateTime?
  purchaseProofReviewedAt     DateTime?
  purchaseProofRejectReason   String?
  productPurchasedConfirmedAt DateTime?
  videoReviewStatus           CreatorMissionVideoReviewStatus @default(NOT_SUBMITTED)
  videoReviewFeedback         String?
  videoSubmittedAt            DateTime?
  videoReviewedAt             DateTime?
  publishStatus               CreatorMissionPublishStatus     @default(NOT_SUBMITTED)
  publishFeedback             String?
  publishSubmittedAt          DateTime?
  publishReviewedAt           DateTime?
  publishPurchaseAmountVnd    Int?
  reimbursementAmountVnd      Int?
  rewardCreditedAt            DateTime?
  assignedAt                  DateTime                        @default(now())
  startedAt                   DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime                        @default(now())
  updatedAt                   DateTime                        @updatedAt

  mission            Mission             @relation(fields: [missionId], references: [id], onDelete: Restrict)
  campaign           Campaign            @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  account            Account             @relation(fields: [accountId], references: [id], onDelete: Restrict)
  submission         MissionSubmission?  @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  missionApplication MissionApplication? @relation(fields: [missionApplicationId], references: [id], onDelete: SetNull)

  @@unique([missionId, accountId])
  @@index([applicationStatus, appliedAt])
  @@index([submissionStatus, updatedAt])
  @@index([accountId, status, createdAt])
  @@index([campaignId, status, createdAt])
}

model ProofReview {
  id           String         @id @default(cuid())
  submissionId String
  missionId    String
  reviewerId   String
  reviewerRole Role
  decision     ReviewDecision
  rejectReason String?
  note         String?
  createdAt    DateTime       @default(now())

  submission MissionSubmission @relation(fields: [submissionId], references: [id])
  mission    Mission           @relation(fields: [missionId], references: [id])
  reviewer   Account           @relation(fields: [reviewerId], references: [id])

  @@index([submissionId, createdAt])
}

model Contribution {
  id                   String                    @id @default(cuid())
  campaignId           String
  supporterId          String
  rewardId             String?
  paymentMethod        ContributionPaymentMethod @default(N_POINTS)
  status               ContributionStatus        @default(PENDING)
  idempotencyKey       String?
  paymentTransactionId String?
  amountVnd            Int
  note                 String?
  createdAt            DateTime                  @default(now())

  campaign           Campaign            @relation(fields: [campaignId], references: [id])
  supporter          Account             @relation(fields: [supporterId], references: [id])
  reward             Reward?             @relation(fields: [rewardId], references: [id])
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])
  rewardClaim        RewardClaim?

  @@unique([supporterId, idempotencyKey])
}

model Reward {
  id                  String     @id @default(cuid())
  campaignId          String
  title               String
  description         String?
  rewardType          RewardType @default(DIGITAL_VOUCHER)
  pointsCost          Int
  stockTotal          Int
  stockRemaining      Int
  isActive            Boolean    @default(true)
  estimatedDeliveryAt DateTime?
  createdAt           DateTime   @default(now())

  campaign      Campaign       @relation(fields: [campaignId], references: [id])
  contributions Contribution[]
  claims        RewardClaim[]
}

model RewardClaim {
  id              String           @id @default(cuid())
  rewardId        String
  contributionId  String           @unique
  accountId       String
  voucherCode     String           @unique
  status          VoucherStatus    @default(ISSUED)
  usageType       VoucherUsageType @default(ONE_TIME)
  expiryAt        DateTime?
  activatedAt     DateTime?
  usedAt          DateTime?
  cancelledAt     DateTime?
  cancelledReason String?
  createdAt       DateTime         @default(now())

  reward       Reward       @relation(fields: [rewardId], references: [id])
  contribution Contribution @relation(fields: [contributionId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model Wallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  pointsBalance  Int      @default(0)
  cashBalanceVnd Int      @default(0)
  updatedAt      DateTime @updatedAt

  user                Account              @relation(fields: [userId], references: [id])
  ledgerEntries       WalletLedger[]
  transactions        WalletTransaction[]
  paymentTransactions PaymentTransaction[]
  payoutRequests      PayoutRequest[]
}

model WalletTransaction {
  id                  String                @id @default(cuid())
  walletId            String
  accountId           String
  type                WalletTransactionType
  pointsDelta         Int                   @default(0)
  cashDeltaVnd        Int                   @default(0)
  balanceAfterPoints  Int
  balanceAfterCashVnd Int
  referenceType       String?
  referenceId         String?
  idempotencyKey      String?
  createdAt           DateTime              @default(now())

  wallet               Wallet               @relation(fields: [walletId], references: [id])
  account              Account              @relation(fields: [accountId], references: [id])
  nPointApprovedTopups NPointTopupRequest[] @relation("NPointTopupWalletTransaction")

  @@unique([walletId, idempotencyKey])
  @@index([walletId, createdAt])
  @@index([accountId, createdAt])
}

model NPointTopupRequest {
  id                   String                   @id @default(cuid())
  brandId              String
  requesterAccountId   String
  amountVnd            Int
  requestedPoints      Int
  transferNote         String
  bankTransferProofUrl String
  status               NPointTopupRequestStatus @default(PENDING_ADMIN_REVIEW)
  adminDecisionReason  String?
  reviewedById         String?
  reviewedAt           DateTime?
  approvedAt           DateTime?
  walletTransactionId  String?                  @unique
  refundBankName       String?
  refundAccountName    String?
  refundAccountNumber  String?
  refundRequestNote    String?
  refundSubmittedAt    DateTime?
  refundProofUrl       String?
  refundProcessedNote  String?
  refundProcessedById  String?
  refundProcessedAt    DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  brand             Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  requester         Account            @relation("NPointTopupRequester", fields: [requesterAccountId], references: [id], onDelete: Restrict)
  reviewedBy        Account?           @relation("NPointTopupReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  refundProcessedBy Account?           @relation("NPointRefundProcessor", fields: [refundProcessedById], references: [id], onDelete: SetNull)
  walletTransaction WalletTransaction? @relation("NPointTopupWalletTransaction", fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([brandId, status, createdAt])
  @@index([requesterAccountId, createdAt])
  @@index([status, updatedAt])
}

model PaymentTransaction {
  id                   String                   @id @default(cuid())
  walletId             String
  accountId            String
  provider             String
  idempotencyKey       String
  orderCode            String                   @unique
  requestedAmountVnd   Int
  creditedPoints       Int
  gatewayTransactionId String?
  status               PaymentTransactionStatus @default(PENDING)
  rawPayload           Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  wallet        Wallet         @relation(fields: [walletId], references: [id])
  account       Account        @relation(fields: [accountId], references: [id])
  contributions Contribution[]

  @@unique([accountId, idempotencyKey])
  @@index([walletId, status, createdAt])
}

model PayoutRequest {
  id             String              @id @default(cuid())
  accountId      String
  walletId       String
  amountVnd      Int
  status         PayoutRequestStatus @default(PENDING)
  note           String?
  reviewedById   String?
  reviewedAt     DateTime?
  paidAt         DateTime?
  idempotencyKey String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  wallet  Wallet  @relation(fields: [walletId], references: [id])

  @@unique([accountId, idempotencyKey])
  @@index([accountId, status, createdAt])
}

model WalletLedger {
  id           String          @id @default(cuid())
  walletId     String
  entryType    TransactionType
  pointsDelta  Int
  cashDeltaVnd Int
  description  String
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model PaymentOrder {
  id         String            @id @default(cuid())
  campaignId String
  orderCode  String            @unique
  amountVnd  Int
  provider   String
  status     TransactionStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

model Notification {
  id             String                     @id @default(cuid())
  accountId      String
  event          NotificationEvent
  channel        NotificationChannel        @default(IN_APP)
  title          String
  content        String
  metadata       Json?
  isRead         Boolean                    @default(false)
  readAt         DateTime?
  deliveryStatus NotificationDeliveryStatus @default(QUEUED)
  sentAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([accountId, isRead, createdAt])
}

model AnalyticsDaily {
  id          String   @id @default(cuid())
  date        DateTime
  campaignId  String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  supports    Int      @default(0)
  supportVnd  Int      @default(0)
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([date, campaignId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  Role?
  action     String
  targetType String
  targetId   String
  oldStatus  String?
  newStatus  String?
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor Account? @relation(fields: [actorId], references: [id])
}

model RiskFlag {
  id         String   @id @default(cuid())
  accountId  String?
  targetType String
  targetId   String
  reason     String
  flagType   String?
  severity   RiskSeverity   @default(MEDIUM)
  status     RiskFlagStatus @default(OPEN)
  note       String?
  resolvedAt DateTime?
  resolvedById String?
  score      Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account    Account? @relation("RiskFlagAccount", fields: [accountId], references: [id])
  resolvedBy Account? @relation("RiskFlagResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
}

model InternalNote {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  content    String
  actorId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  actor Account @relation("InternalNoteActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([actorId, createdAt])
}

model SupportTicket {
  id                  String                @id @default(cuid())
  requesterAccountId  String
  assigneeAccountId   String?
  title               String
  description         String
  status              SupportTicketStatus   @default(OPEN)
  priority            SupportTicketPriority @default(MEDIUM)
  category            SupportTicketCategory @default(OTHER)
  responseSummary     String?
  internalNote        String?
  relatedBrandId      String?
  relatedCreatorId    String?
  relatedCampaignId   String?
  relatedOrderId      String?
  relatedPayoutId     String?
  relatedSubmissionId String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  requester Account                @relation("SupportTicketRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)
  assignee  Account?               @relation("SupportTicketAssignee", fields: [assigneeAccountId], references: [id], onDelete: SetNull)
  comments  SupportTicketComment[]

  @@index([status, priority, createdAt])
  @@index([requesterAccountId, createdAt])
  @@index([assigneeAccountId, status, createdAt])
}

model SupportTicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  message    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author Account       @relation("SupportTicketCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  eventName  AnalyticsEventName
  userId     String?
  sessionId  String
  campaignId String?
  brandId    String?
  creatorId  String?
  metadata   Json?
  createdAt  DateTime           @default(now())

  user     Account?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
  @@index([brandId, createdAt])
  @@index([creatorId, createdAt])
}

model AdminSetting {
  id                          String   @id @default(cuid())
  scope                       String   @unique @default("global")
  reviewSlaHours              Int      @default(24)
  payoutAutoThresholdVnd      Int      @default(5000000)
  fraudScoreThreshold         Int      @default(70)
  requireRejectReason         Boolean  @default(true)
  requireRequestChangesReason Boolean  @default(true)
  maintenanceMessage          String   @default("")
  campaignContentTemplateUrl  String   @default("")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}
