generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CREATOR
  BRAND_OWNER
  BRAND_STAFF
  ADMIN
  OPS
}

enum ApplicationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum SocialPlatform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
  FACEBOOK
  OTHER
}

enum BrandMemberRole {
  OWNER
  STAFF
}

enum BrandStatus {
  ACTIVE
  SUSPENDED
  REJECTED
  PENDING_VERIFICATION
}

enum FulfillmentType {
  NONE_WAREHOUSE
  BRAND_FULFILLMENT
}

enum OpsReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RoleRequestType {
  CREATOR
  BRAND
}

enum RoleRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignType {
  DONATION
  PREORDER
  SPONSORSHIP
  COMMUNITY
}

enum CampaignSetupSource {
  JOIN_EXISTING_DCREATOR_CAMP
  BRAND_REQUESTED
}

enum CampaignFeasibilityStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  NEEDS_ADJUSTMENT
  REJECTED
}

enum BrandCampaignApprovalStatus {
  DRAFT
  WAITING_DCREATOR_REVIEW
  WAITING_BRAND_APPROVAL
  APPROVED
  CHANGE_REQUESTED
}

enum BrandCampaignRequestStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum CampaignCategory {
  TECH
  FASHION
  FOOD
  BEAUTY
  LIFESTYLE
  EDUCATION
}

enum MissionStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
}

enum MissionAudience {
  USER
  CREATOR
}

enum MissionLifecycleStatus {
  OPEN
  ACCEPTED
  DOING
  SUBMITTED
  PENDING_REVIEW
  APPROVED
  DONE
  REJECTED
  EXPIRED
  CANCELLED
}

enum ReviewDecision {
  APPROVED
  REJECTED
}

enum TransactionType {
  TOPUP
  SUPPORT
  REWARD_REDEEM
  PAYOUT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum WalletTransactionType {
  TOPUP
  SUPPORT
  REWARD_REDEEM
  COMMISSION_CREDIT
  COMMISSION_PAYOUT
  ADJUSTMENT
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ContributionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ContributionPaymentMethod {
  N_POINTS
  PAYOS
}

enum RewardType {
  PHYSICAL_PRODUCT
  DIGITAL_VOUCHER
  EXPERIENCE
  CREATOR_PERK
  DISCOUNT_CODE
}

enum VoucherStatus {
  ISSUED
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum VoucherUsageType {
  ONE_TIME
  MULTI_USE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum NotificationEvent {
  USER_CONTRIBUTION_SUCCESS
  USER_RECEIVED_VOUCHER
  MISSION_ACCEPTED
  PROOF_SUBMITTED
  PROOF_APPROVED
  PROOF_REJECTED
  CREATOR_APPLICATION_APPROVED
  BRAND_APPLICATION_APPROVED
  CAMPAIGN_APPROVED
  CAMPAIGN_REJECTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYOUT_REQUESTED
  PAYOUT_APPROVED
  PAYOUT_REJECTED
}

enum AnalyticsEventName {
  campaign_view
  campaign_cta_click
  campaign_support_started
  campaign_contribution_success
  reward_selected
  voucher_issued
  voucher_redeemed
  mission_accept
  mission_submit
  proof_approved
  proof_rejected
  creator_apply_job
  brand_create_campaign
  payment_success
  payment_failed
}

model Account {
  id             String             @id @default(cuid())
  email          String             @unique
  passwordHash   String?
  displayName    String
  avatarUrl      String?
  role           Role
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaigns      Campaign[]         @relation("CampaignBrand")
  campaignsAsCreator Campaign[]     @relation("CampaignCreator")
  wallet         Wallet?
  profile        Profile?
  submissions    MissionSubmission[]
  proofReviews   ProofReview[]
  supports       Contribution[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  riskFlags      RiskFlag[]         @relation("RiskFlagAccount")
  sessions       AuthSession[]
  roleRequests   RoleRequest[]      @relation("RoleRequestApplicant")
  reviewedRoleRequests RoleRequest[] @relation("RoleRequestReviewer")
  walletTransactions WalletTransaction[]
  paymentTransactions PaymentTransaction[]
  payoutRequests   PayoutRequest[]
  rewardClaims    RewardClaim[]
  analyticsEvents AnalyticsEvent[]
  roleAssignments AccountRole[]
  creatorApplications CreatorApplication[]
  creatorProfile CreatorProfile?
  brandApplications BrandApplication[]
  ownedBrandMemberships BrandMember[] @relation("BrandMemberAccount")
  reviewedCreatorApplications CreatorApplication[] @relation("CreatorApplicationReviewer")
  reviewedBrandApplications BrandApplication[] @relation("BrandApplicationReviewer")
  reviewedBrands Brand[] @relation("BrandReviewer")
  reviewedBrandCampaignRequests BrandCampaignRequest[] @relation("BrandCampaignRequestReviewer")
  ownedBrands Brand[] @relation("BrandOwner")
}

model AccountRole {
  id             String   @id @default(cuid())
  accountId      String
  role           Role
  createdAt      DateTime @default(now())

  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, role])
  @@index([role, createdAt])
}

model CreatorApplication {
  id               String            @id @default(cuid())
  accountId        String
  status           ApplicationStatus @default(PENDING_REVIEW)
  displayName      String
  avatarUrl        String?
  bio              String?
  mainPlatform     SocialPlatform
  socialUrl        String
  handle           String?
  followerCount    Int?
  contentCategory  String?
  portfolioUrl     String?
  location         String?
  expectedRate     Int?
  maxJobsPerMonth  Int?
  realName         String?
  phone            String?
  identityNumber   String?
  identityFrontUrl String?
  identityBackUrl  String?
  selfieUrl        String?
  bankAccountName  String?
  bankAccountNumber String?
  bankName         String?
  taxCode          String?
  rejectReason     String?
  reviewNote       String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy       Account?          @relation("CreatorApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model CreatorProfile {
  id                String   @id @default(cuid())
  accountId         String   @unique
  displayName       String
  avatarUrl         String?
  bio               String?
  mainPlatform      SocialPlatform
  socialUrl         String
  handle            String?
  followerCount     Int?
  contentCategory   String?
  portfolioUrl      String?
  location          String?
  expectedRate      Int?
  maxJobsPerMonth   Int?
  realName          String?
  phone             String?
  identityNumber    String?
  identityFrontUrl  String?
  identityBackUrl   String?
  selfieUrl         String?
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?
  taxCode           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account           Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model BrandApplication {
  id                           String            @id @default(cuid())
  accountId                    String
  status                       ApplicationStatus @default(PENDING_REVIEW)
  brandName                    String
  logoUrl                      String?
  legalName                    String?
  industry                     String?
  website                      String?
  fanpage                      String?
  address                      String?
  contactName                  String
  contactPhone                 String
  contactEmail                 String
  description                  String?
  businessGoal                 String?
  taxCode                      String?
  businessLicenseUrl           String?
  representativeName           String?
  representativePhone          String?
  representativeEmail          String?
  representativeIdentityNumber String?
  bankAccountName              String?
  bankAccountNumber            String?
  bankName                     String?
  productCategories            String?
  inventoryDescription         String?
  expectedCampaignBudget       Int?
  expectedCreatorCount         Int?
  revenueSharePercent          Int?
  commissionRatePercent        Int?
  bccAgreementAccepted         Boolean           @default(false)
  bccAgreementVersion          String?
  bccAgreementTerms            String?
  legalResponsibilityAccepted  Boolean           @default(false)
  contractFileUrl              String?
  contractSignedAt             DateTime?
  rejectReason                 String?
  reviewNote                   String?
  reviewedById                 String?
  reviewedAt                   DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  account                      Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy                   Account?          @relation("BrandApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model Brand {
  id                  String      @id @default(cuid())
  ownerAccountId      String
  name                String
  logoUrl             String?
  legalName           String?
  industry            String?
  website             String?
  fanpage             String?
  address             String?
  contactName         String
  contactPhone        String
  contactEmail        String
  description         String?
  businessGoal        String?
  taxCode             String?
  businessLicenseUrl  String?
  representativeName  String?
  representativePhone String?
  representativeEmail String?
  productCategories   String?
  inventoryDescription String?
  revenueSharePercent Int?
  commissionRatePercent Int?
  bccAgreementVersion String?
  bccAgreementTerms   String?
  legalResponsibilityAccepted Boolean @default(false)
  contractFileUrl     String?
  contractSignedAt    DateTime?
  status              BrandStatus @default(PENDING_VERIFICATION)
  reviewedById        String?
  reviewedAt          DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  owner               Account     @relation("BrandOwner", fields: [ownerAccountId], references: [id], onDelete: Restrict)
  reviewedBy          Account?    @relation("BrandReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  members             BrandMember[]
  products            BrandProduct[]
  campaignRequests    BrandCampaignRequest[]
}

model BrandCampaignRequest {
  id                       String                     @id @default(cuid())
  brandId                  String
  requestedSlug            String
  title                    String
  brief                    String
  setupSource              CampaignSetupSource        @default(BRAND_REQUESTED)
  objective                String?
  priorityChannels         String?
  missionTypes             String?
  creatorCommissionPercent Int                        @default(0)
  userCommissionPercent    Int                        @default(0)
  bonusBudgetVnd           Int                        @default(0)
  budgetVnd                Int
  targetAmountVnd          Int                        @default(10000000)
  campaignType             CampaignType               @default(COMMUNITY)
  category                 CampaignCategory           @default(LIFESTYLE)
  startsAt                 DateTime?
  endsAt                   DateTime?
  status                   BrandCampaignRequestStatus @default(PENDING_REVIEW)
  adminNote                String?
  brandFeedback            String?
  createdCampaignId        String?
  reviewedById             String?
  reviewedAt               DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  brand                    Brand                      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  createdCampaign          Campaign?                  @relation("CampaignFromBrandRequest", fields: [createdCampaignId], references: [id], onDelete: SetNull)
  reviewedBy               Account?                   @relation("BrandCampaignRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([brandId, createdAt])
  @@index([status, createdAt])
  @@index([createdCampaignId])
}

model BrandProduct {
  id                  String                @id @default(cuid())
  brandId             String
  sku                 String
  name                String
  description         String?
  imageUrl            String?
  stockQty            Int                   @default(0)
  voucherStock        Int                   @default(0)
  campaignEligibility Boolean               @default(true)
  suggestedPriceVnd   Int                   @default(0)
  costPriceVnd        Int                   @default(0)
  priceVnd            Int                   @default(0)
  pricePoints         Int                   @default(0)
  returnPolicy        String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  brand               Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  batches             BrandInventoryBatch[]

  @@unique([brandId, sku])
  @@index([brandId, createdAt])
  @@index([campaignEligibility])
}

model BrandInventoryBatch {
  id                  String          @id @default(cuid())
  productId           String
  quantity            Int             @default(0)
  expiryDate          DateTime?
  fulfillmentType     FulfillmentType @default(BRAND_FULFILLMENT)
  opsStatus           OpsReviewStatus @default(PENDING_REVIEW)
  appraisedValueVnd   Int             @default(0)
  viableMarginPercent Int             @default(0)
  opsNote             String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  product             BrandProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([opsStatus])
}

model BrandMember {
  id         String          @id @default(cuid())
  brandId    String
  accountId  String
  role       BrandMemberRole @default(STAFF)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  brand      Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  account    Account         @relation("BrandMemberAccount", fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([brandId, accountId])
  @@index([accountId, role])
}

model AuthSession {
  id             String   @id @default(cuid())
  accountId      String
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model RoleRequest {
  id             String            @id @default(cuid())
  accountId      String
  type           RoleRequestType
  status         RoleRequestStatus @default(PENDING)
  brandName      String?
  brandWebsite   String?
  note           String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  account        Account           @relation("RoleRequestApplicant", fields: [accountId], references: [id], onDelete: Cascade)
  reviewedBy     Account?          @relation("RoleRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([accountId, status])
  @@index([type, status])
}

model Profile {
  id             String   @id @default(cuid())
  accountId      String   @unique
  bio            String?
  phone          String?
  socialLinks    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account        Account  @relation(fields: [accountId], references: [id])
}

model Campaign {
  id             String           @id @default(cuid())
  brandId        String
  creatorId      String?
  slug           String           @unique
  title          String
  brief          String
  coverImageUrl  String?
  campaignType   CampaignType      @default(COMMUNITY)
  setupSource    CampaignSetupSource @default(BRAND_REQUESTED)
  objective      String?
  priorityChannels String?
  missionTypes   String?
  creatorCommissionPercent Int      @default(0)
  userCommissionPercent Int         @default(0)
  bonusBudgetVnd Int                @default(0)
  feasibilityStatus CampaignFeasibilityStatus @default(DRAFT)
  feasibilityNote String?
  brandApprovalStatus BrandCampaignApprovalStatus @default(DRAFT)
  brandFeedback   String?
  category       CampaignCategory  @default(LIFESTYLE)
  targetAmountVnd Int              @default(10000000)
  fundedAmountVnd Int              @default(0)
  backerCount     Int              @default(0)
  isPublic       Boolean           @default(true)
  budgetVnd      Int
  status         CampaignStatus   @default(DRAFT)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  brand          Account          @relation("CampaignBrand", fields: [brandId], references: [id])
  creator        Account?         @relation("CampaignCreator", fields: [creatorId], references: [id])
  missions       Mission[]
  rewards        Reward[]
  contributions  Contribution[]
  paymentOrders  PaymentOrder[]
  analytics      AnalyticsDaily[]
  analyticsEvents AnalyticsEvent[]
  sourceBrandRequests BrandCampaignRequest[] @relation("CampaignFromBrandRequest")
}

model Mission {
  id             String              @id @default(cuid())
  campaignId     String
  title          String
  description    String
  rewardPoints   Int
  rewardCommissionVnd Int            @default(0)
  audience       MissionAudience     @default(USER)
  allowRepeat    Boolean             @default(false)
  deadlineAt     DateTime?
  status         MissionStatus       @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  campaign       Campaign            @relation(fields: [campaignId], references: [id])
  proofReviews   ProofReview[]
  submissions    MissionSubmission[]
}

model MissionSubmission {
  id             String        @id @default(cuid())
  missionId      String
  accountId      String
  lifecycleStatus MissionLifecycleStatus @default(ACCEPTED)
  videoUrl       String?
  imageUrl       String?
  socialPostUrl  String?
  screenshotUrl  String?
  fileUploadUrl  String?
  proofTextNote  String?
  note           String?
  rejectReason   String?
  approvedAt     DateTime?
  rewardGrantedAt DateTime?
  status         MissionStatus @default(SUBMITTED)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  mission        Mission       @relation(fields: [missionId], references: [id])
  account        Account       @relation(fields: [accountId], references: [id])
  reviews        ProofReview[]

  @@unique([missionId, accountId])
  @@index([accountId, lifecycleStatus, createdAt])
}

model ProofReview {
  id               String         @id @default(cuid())
  submissionId     String
  missionId        String
  reviewerId       String
  reviewerRole     Role
  decision         ReviewDecision
  rejectReason     String?
  note             String?
  createdAt        DateTime       @default(now())

  submission       MissionSubmission @relation(fields: [submissionId], references: [id])
  mission          Mission        @relation(fields: [missionId], references: [id])
  reviewer         Account        @relation(fields: [reviewerId], references: [id])

  @@index([submissionId, createdAt])
}

model Contribution {
  id             String            @id @default(cuid())
  campaignId     String
  supporterId    String
  rewardId       String?
  paymentMethod  ContributionPaymentMethod @default(N_POINTS)
  status         ContributionStatus @default(PENDING)
  idempotencyKey String?
  paymentTransactionId String?
  amountVnd      Int
  note           String?
  createdAt      DateTime          @default(now())

  campaign       Campaign          @relation(fields: [campaignId], references: [id])
  supporter      Account           @relation(fields: [supporterId], references: [id])
  reward         Reward?           @relation(fields: [rewardId], references: [id])
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id])
  rewardClaim    RewardClaim?

  @@unique([supporterId, idempotencyKey])
}

model Reward {
  id             String   @id @default(cuid())
  campaignId     String
  title          String
  description    String?
  rewardType     RewardType @default(DIGITAL_VOUCHER)
  pointsCost     Int
  stockTotal     Int
  stockRemaining Int
  isActive       Boolean  @default(true)
  estimatedDeliveryAt DateTime?
  createdAt      DateTime @default(now())

  campaign       Campaign @relation(fields: [campaignId], references: [id])
  contributions  Contribution[]
  claims         RewardClaim[]
}

model RewardClaim {
  id             String   @id @default(cuid())
  rewardId       String
  contributionId String   @unique
  accountId      String
  voucherCode    String   @unique
  status         VoucherStatus @default(ISSUED)
  usageType      VoucherUsageType @default(ONE_TIME)
  expiryAt       DateTime?
  activatedAt    DateTime?
  usedAt         DateTime?
  cancelledAt    DateTime?
  cancelledReason String?
  createdAt      DateTime @default(now())

  reward         Reward   @relation(fields: [rewardId], references: [id])
  contribution   Contribution @relation(fields: [contributionId], references: [id])
  account        Account  @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model Wallet {
  id             String              @id @default(cuid())
  userId         String              @unique
  pointsBalance  Int                 @default(0)
  cashBalanceVnd Int                 @default(0)
  updatedAt      DateTime            @updatedAt

  user           Account             @relation(fields: [userId], references: [id])
  ledgerEntries  WalletLedger[]
  transactions   WalletTransaction[]
  paymentTransactions PaymentTransaction[]
  payoutRequests PayoutRequest[]
}

model WalletTransaction {
  id             String                @id @default(cuid())
  walletId       String
  accountId      String
  type           WalletTransactionType
  pointsDelta    Int                   @default(0)
  cashDeltaVnd   Int                   @default(0)
  balanceAfterPoints Int
  balanceAfterCashVnd Int
  referenceType  String?
  referenceId    String?
  idempotencyKey String?
  createdAt      DateTime              @default(now())

  wallet         Wallet                @relation(fields: [walletId], references: [id])
  account        Account               @relation(fields: [accountId], references: [id])

  @@index([walletId, createdAt])
  @@index([accountId, createdAt])
  @@unique([walletId, idempotencyKey])
}

model PaymentTransaction {
  id                 String                    @id @default(cuid())
  walletId           String
  accountId          String
  provider           String
  idempotencyKey     String
  orderCode          String                    @unique
  requestedAmountVnd Int
  creditedPoints     Int
  gatewayTransactionId String?
  status             PaymentTransactionStatus  @default(PENDING)
  rawPayload         Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  wallet             Wallet                    @relation(fields: [walletId], references: [id])
  account            Account                   @relation(fields: [accountId], references: [id])
  contributions      Contribution[]

  @@unique([accountId, idempotencyKey])
  @@index([walletId, status, createdAt])
}

model PayoutRequest {
  id                 String               @id @default(cuid())
  accountId          String
  walletId           String
  amountVnd          Int
  status             PayoutRequestStatus  @default(PENDING)
  note               String?
  reviewedById       String?
  reviewedAt         DateTime?
  paidAt             DateTime?
  idempotencyKey     String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  account            Account              @relation(fields: [accountId], references: [id])
  wallet             Wallet               @relation(fields: [walletId], references: [id])

  @@unique([accountId, idempotencyKey])
  @@index([accountId, status, createdAt])
}

model WalletLedger {
  id             String            @id @default(cuid())
  walletId       String
  entryType      TransactionType
  pointsDelta    Int
  cashDeltaVnd   Int
  description    String
  createdAt      DateTime          @default(now())

  wallet         Wallet            @relation(fields: [walletId], references: [id])
}

model PaymentOrder {
  id             String            @id @default(cuid())
  campaignId     String
  orderCode      String            @unique
  amountVnd      Int
  provider       String
  status         TransactionStatus @default(PENDING)
  createdAt      DateTime          @default(now())

  campaign       Campaign          @relation(fields: [campaignId], references: [id])
}

model Notification {
  id             String                       @id @default(cuid())
  accountId      String
  event          NotificationEvent
  channel        NotificationChannel          @default(IN_APP)
  title          String
  content        String
  metadata       Json?
  isRead         Boolean                      @default(false)
  readAt         DateTime?
  deliveryStatus NotificationDeliveryStatus   @default(QUEUED)
  sentAt         DateTime?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  account        Account                      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([accountId, isRead, createdAt])
}

model AnalyticsDaily {
  id             String   @id @default(cuid())
  date           DateTime
  campaignId     String
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  supports       Int      @default(0)
  supportVnd     Int      @default(0)
  createdAt      DateTime @default(now())

  campaign       Campaign @relation(fields: [campaignId], references: [id])

  @@unique([date, campaignId])
}

model AuditLog {
  id             String   @id @default(cuid())
  actorId        String?
  action         String
  targetType     String
  targetId       String
  metadata       Json?
  createdAt      DateTime @default(now())

  actor          Account? @relation(fields: [actorId], references: [id])
}

model RiskFlag {
  id             String   @id @default(cuid())
  accountId      String?
  targetType     String
  targetId       String
  reason         String
  score          Int      @default(0)
  metadata       Json?
  createdAt      DateTime @default(now())

  account        Account? @relation("RiskFlagAccount", fields: [accountId], references: [id])
}

model AnalyticsEvent {
  id             String             @id @default(cuid())
  eventName      AnalyticsEventName
  userId         String?
  sessionId      String
  campaignId     String?
  brandId        String?
  creatorId      String?
  metadata       Json?
  createdAt      DateTime           @default(now())

  user           Account?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaign       Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([campaignId, createdAt])
  @@index([brandId, createdAt])
  @@index([creatorId, createdAt])
}
