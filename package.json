{
  "name": "dcreator-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "vercel-build": "npm run db:generate --workspace=web && turbo run build --filter=web",
    "dev": "npm run db:prepare -w web && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
